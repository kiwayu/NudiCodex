# NudiCodex frontend environment
#
# Copy to `.env` and fill in. Without these, the app runs in guest-only mode
# (collection saved in the browser). Add them to enable accounts + cloud sync.
#
# Create a free project at https://supabase.com, then find these under
# Project Settings -> API. The anon key is safe to expose in the client;
# Row-Level Security protects each user's data.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
